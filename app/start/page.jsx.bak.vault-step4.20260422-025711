import { useEffect, useMemo, useState } from 'react'
import { useRouter } from 'next/navigation'

function formatFutureDate(days) {
  const d = new Date()
  d.setDate(d.getDate() + days)
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

