                    fontFamily: '"Cormorant Garamond", serif',
                    fontSize: '18px',
                    lineHeight: '1.45',
                    color: 'rgba(31,46,35,0.80)',
                    textAlign: 'center',
                  }}>
                    From: You<br />
                    Delivered on<br />
                    {deliveryDate}
                  </div>
                </div>
              </div>
            </div>

            <div style={{
              fontFamily: '"Cormorant Garamond", serif',
              fontSize: '22px',
              lineHeight: '1.75',
              color: '#173A2C',
            }}>
              <div><strong>To:</strong> {recipientName || 'Sarah Johnson'}</div>
              <div><strong>From:</strong> You</div>
              <div><strong>Trigger:</strong> {deliveryLabelMap[deliveryRule]}</div>
              <div><strong>Estimated delivery:</strong> {deliveryDate}</div>
            </div>
          </div>

          <div style={previewCard}>
            <div style={previewTitle}>Message Preview</div>
            <div style={{
              position: 'relative',
              minHeight: '286px',
              overflow: 'hidden',
            }}>
              <div style={shine()} />
              <div style={previewMessage}>{messagePreview}</div>
            </div>
          </div>
        </div>

        <div style={centeredNote}>This is what they would receive.</div>

        <div style={footerRow}>
          <button style={backButton} onClick={back}>← Back</button>
          <div style={{ flex: 1 }}>
            <button style={goldButton} onClick={finish}>Make This Real →</button>
          </div>
        </div>

        {renderPrivacy()}
      </>
    )
  }

  return (
    <div style={page}>
      <div style={shell}>
        <div style={leftPanel}>
  <img
    src="/reference/assets/vault-door-reference.png"
    style={{
      width: '85%',
      height: 'auto',
      maxHeight: '90%',
      objectFit: 'contain',
      filter: 'contrast(1.05) brightness(0.98)',
    }}
  />
</div>

        <div style={rightPanel}>
          <div style={headerRow}>
            <div style={brand}>Legacy Vault</div>

            <div style={progress}>
              {[1, 2, 3, 4].map((n) => (
                <div key={n} style={progressItem(n)}>
                  {n}
                  <div style={progressUnderline(n)} />
                </div>
              ))}
            </div>
          </div>

          {step === 1 ? renderStep1() : null}
          {step === 2 ? renderStep2() : null}
          {step === 3 ? renderStep3() : null}
          {step === 4 ? renderStep4() : null}
        </div>
      </div>
    </div>
  )
}
