    const t1 = setTimeout(() => setSimulationPhase(1), 400)
    const t2 = setTimeout(() => setSimulationPhase(2), 1100)
    const t3 = setTimeout(() => setSimulationPhase(3), 2200)

    return () => {
      clearTimeout(t1)
      clearTimeout(t2)
      clearTimeout(t3)
    }
  }, [step, recipientName, recipientEmail, messageText, deliveryRule])

  const validate = () => {
    const nextErrors = {}

    if (step === 1) {
      if (!recipientName.trim()) nextErrors.recipientName = 'Please enter the recipient name.'
      if (!recipientEmail.trim()) {
        nextErrors.recipientEmail = 'Please enter the recipient email.'
      } else if (!/\S+@\S+\.\S+/.test(recipientEmail)) {
        nextErrors.recipientEmail = 'Please enter a valid email.'
      }
    }

    if (step === 2) {
      if (!messageType) nextErrors.messageType = 'Please choose a message type.'
      if (messageType === 'text' && !messageText.trim()) {
        nextErrors.messageText = 'Please write your message.'
      }
    }

    if (step === 3) {
      if (!deliveryRule) nextErrors.deliveryRule = 'Please choose a delivery trigger.'
    }

    setErrors(nextErrors)
    return Object.keys(nextErrors).length === 0
  }

  const next = () => {
    if (!validate()) return
    setErrors({})
    setStep((s) => s + 1)
  }

  const back = () => {
    setErrors({})
    setStep((s) => s - 1)
  }

